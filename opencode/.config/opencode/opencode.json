{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoupdate": true,
  "model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "bash": {
      "*": "deny",
      "git status": "allow",
      "git diff": "allow",
      "git fetch": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "ls *": "allow",
      "pwd": "allow"
    }
  },
  "mcp": {
    "linear": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse"
    },
    "notion": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/sse"]
    }
  },
  "tools": {
    "linear": false,
    "figma": false,
    "notion": false
  }
}
