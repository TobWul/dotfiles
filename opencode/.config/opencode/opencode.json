{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "github-copilot/claude-opus-4.6",
  "permission": {
    "bash": {
      "*": "deny",
      "bd*": "allow",

      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",

      "grep *": "allow",
      "rg *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",

      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote -v": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",

      "node --version": "allow",
      "npm --version": "allow",
      "pnpm --version": "allow",
      "git --version": "allow",

      "npm install": "allow",
      "npm install*": "ask",
      "npm run*": "ask",
      "npm run check*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "npm run build*": "allow",

      "bun install": "allow",
      "bun install*": "ask",
      "bun run*": "ask",
      "bun run check*": "allow",
      "bun run test*": "allow",
      "bun run lint*": "allow",
      "bun run build*": "allow",

      "pnpm install": "allow",
      "pnpm install*": "ask",
      "pnpm run*": "ask",
      "pnpm run check*": "allow",
      "pnpm run test*": "allow",
      "pnpm run lint*": "allow",
      "pnpm run build*": "allow",

      "npx *": "ask",
      "npx tsc *": "allow",
      "node *": "ask",

      "cd *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "mv *": "ask",
      "rm *": "ask"
    }
  },
  "mcp": {
    "linear": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse"
    },
    "notion": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/sse"]
    }
  },
  "tools": {
    "linear": false,
    "figma": false,
    "notion": false
  }
}
